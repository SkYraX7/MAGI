# Frontend dev config. The app is origin-relative by default (the Vite proxy and the
# prod nginx forward /auth, /graph, /ws to the backend), so these are rarely needed.

# Where the Vite dev-server proxy forwards API + WS traffic.
VITE_BACKEND_URL=http://localhost:8000

# Optional explicit overrides if you are NOT using the proxy (point straight at backend):
# VITE_API_BASE=http://localhost:8000
# VITE_WS_BASE=ws://localhost:8000
